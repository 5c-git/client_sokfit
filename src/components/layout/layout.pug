                li.swiper-slide.layout__slider-item
                  +news-card({
                    src: './assets/images/image-8.jpg',
                    title: 'Аэро-йога для взрослых и детей',
                  })
                li.swiper-slide.layout__slider-item
                  +news-card({
                    src: './assets/images/image-11.jpg',
                    title: 'Заголовок новости, который может быть очень и очень длинным',
                  })
              div.layout__scrollbar

          if props.all
            a(href="#").layout__all=props.all

  else if props.grid2 
    section.layout.layout--grid2 
