include ../trainer-card/trainer-card
include ../news-card/news-card

mixin layout(props)
  if props.slider1
    section.layout.layout--slider
      div.container 
        div.layout__wrapper

          if props.title
            h2.layout__title!=props.title

          div.layout__slider
            div.swiper
              ul.swiper-wrapper.layout__slider-list
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-1.jpg',
                    title: 'Константин Константинович',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-2.jpg',
                    title: 'Алексеев Антон',
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    title: 'Сергей Харионов',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-4.jpg',
                    title: 'Брюс Уиллис',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-5.jpg',
                    title: 'Софи Брюссо',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-1.jpg',
                    title: 'Константин Константинович',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-2.jpg',
                    title: 'Алексеев Антон',
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-3.jpg',
                    title: 'Сергей Харионов',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-4.jpg',
                    title: 'Брюс Уиллис',
                    tabs: true,
                  })
                li.swiper-slide.layout__slider-item
                  +trainer-card({
                    src: './assets/images/trainer-5.jpg',
                    title: 'Софи Брюссо',
                    tabs: true,
                  })
              div.layout__scrollbar

          if props.all
            a(href="#").layout__all=props.all

  else if props.slider2
    section.layout.layout--slider
      div.container 
        div.layout__wrapper

          if props.title
            h2.layout__title!=props.title

          div.layout__slider
            div.swiper
