include ../zone-card/zone-card
include ../review-card/review-card

mixin slider(props)

  section.slider(
    class=props.mixin
    data-slider=props.type
    data-autoplay=props.autoplay
  )
    div.slider__buttons
      button(type='button' aria-label='Предыдущий слайд.').slider__button.slider__button--prev
        svg(width="59" height="59" viewBox="0 0 59 59" xmlns="http://www.w3.org/2000/svg")
          use(href='#icon-up')

      button(type='button' aria-label='Следующий слайд.').slider__button.slider__button--next
        svg(width="59" height="59" viewBox="0 0 59 59" xmlns="http://www.w3.org/2000/svg")
          use(href='#icon-up')
  
    div.swiper.slider__swiper

      ul.swiper-wrapper.slider__list
        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-1.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-1.jpg',
              title: 'Велнес-куратор',
              text: 'Индивидуальные программы, созданные на основе wellness-аудита и регулярно корректируемые.  Комплексный подход, где тренировки интегрированы с питанием, восстановлением и комьюнити. Технологичные решения для контроля прогресса и удобства. Гибкость форматов под ваш образ жизни. Мы работаем не с изолированными тренировками, а с персональной "картой здоровья", где каждый элемент усиливает другой. Это не просто набор упражнений, а индивидуальный маршрут к цели клиента.',
            })

          if props.review
            +review-card({
              photo: './assets/images/fun-1.jpg',
              text: 'Мой профессиональный путь не был простым и лёгким, но это интересный путь однозначно!<br>Вышла на должность менеджера по продажам в г.. Волгоград. Спустя год работы в компании стала администратором. Проработав 5 лет я поняла, что выросла. Я попросила перевод в Москву и уже через 2 недели поменяла город своей карьеры. Никогда не приходилось мне искать работу, она сама меня находила.<br>И я благодарна судьбе за то, что она всегда окружала меня людьми, которые были моим «фейс-контролем», «гарантом», «проводником» в мир профессии и новой работы.',
              name: 'Деркач Юлия',
              about: '',
            })
            

        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-15.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-4.jpg',
              title: 'Тренажерный зал',
              text: 'Питание как терапия (СОК Баланс) Наш ресторан СОК Баланс — продолжение тренировок. Если обычный ресторан кормит, то СОК Баланс программирует ваше восстановление. В акценте - персонализация питания в зависимости от особенностей здоровья и тренировочного процесса. СОК Баланс — это место, где гастрономия становится точной наукой. Мы не просто кормим — мы программируем ваши результаты через питание.',
            })

          if props.review
            +review-card({
              photo: './assets/images/fun-2.jpg',
              text: 'Мой профессиональный путь не был простым и лёгким, но это интересный путь однозначно!<br>Вышла на должность менеджера по продажам в г.',
              name: 'Деркач Юлия',
              about: '',
            })
            

        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-16.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-2.jpg',
              title: 'Групповые программы',
              text: 'В СОК ВЕЛНЕС восстановление — это система. Вы  получаете доступ к бесплатному термальнобанному комплексу с базовыми услугам (бассейны, сауны, хамам, снежная комната, джакузи, зона релакса), а для углублённой работы с телом работает премиальный SPA-салон СОК Бьюти — наш научный центр восстановления, где каждая процедура подбирается на основе данных вашего wellness аудита. Это не просто релакс, а часть вашей тренировочной программы.',
            })

          if props.review
            +review-card({
              photo: './assets/images/fun-3.jpg',
              text: 'Мой путь в компании начался в 2021 году, когда мне было всего 20 лет. В тот момент у меня было главное — амбиции, энергия и желание делать этот мир лучше . «Эстетика» стала пространством, где эти качества обрели практическое воплощение.<br>Уже через 9 месяцев я получила возможность перейти на позицию старшего менеджера в другом салоне. Это стало для меня подтверждением того, что стремление к развитию, ответственность и искренний интерес к делу всегда находят отклик.Работа в «Эстетике» для меня — это больше, чем профессия. Это путь личностного и профессионального роста, возможность быть частью бренда, который задаёт стандарты премиального сервиса и формирует культуру красоты. Каждый день я убеждаюсь: когда ты любишь своё дело, открываются новые горизонты, а рост и успех становятся естественным продолжением твоего пути.',
              name: 'Деркач Юлия',
              about: '',
            })
            

        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-14.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-3.jpg',
              title: 'Аквазона',
              text: 'Только групповые занятия с понятной программой и поддержка тренера. Также есть возможность заниматься с тренером индивидуально.',
            })

          if props.review
            +review-card({
              photo: './assets/images/fun-4.jpg',
              text: 'Мой путь в компании ESTETICA начался 11 лет назад. Тогда я была обычным менеджером по продажам и только мечтала о том, чтобы однажды достичь большего. <br>На сегодняшний день, я — администратор одного из лучших салонов в центре Москвы, и за каждым шагом моего роста стоит эта компания.ESTETICA подарила мне бесценный опыт: умение всегда стремиться выше, верить в собственные силы и при этом оставаться человеком. Всё это стало возможным благодаря невероятным людям рядом — настоящим профессионалам, которые делятся знаниями, поддерживают и вдохновляют.<br>Мой салон — это отражение моего внутреннего мира. Здесь я могу создавать красоту и стиль, помогая клиентам воплощать их мечты об идеальном интерьере.Я благодарна компании ESTETICA за то, что именно здесь я смогла раскрыть себя, обрести уверенность и стать профессионалом, для которого работа — это вдохновение и любовь к своему делу.',
              name: 'Деркач Юлия',
              about: '',
            })

            
        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-5.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-5.jpg',
              title: 'Зал единоборств',
              text: 'Занятия проходят в мини-группах, тренер может уделить время каждой гостье и адаптировать нагрузку.',
            })

          if props.review
            +review-card({
              photo: './assets/images/fun-5.jpg',
              text: 'Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae dicta sunt explicabo.',
              name: 'Деркач Юлия',
              about: '',
            })

            
        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-8.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-4.jpg',
              title: 'Детский фитнес',
              text: 'Столько проходит каждый тренер перед началом работы в наших клубах. Мы разработали специальную программу и даже получили образовательную лицензию.',
            })

            
        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-10.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-3.jpg',
              title: 'Салон красоты',
              text: 'Клубы работают с раннего утра до позднего вечера, чтобы вы точно нашли подходящий слот для тренировки. В один час может проходить до 5 занятий.',
            })

            
        li.swiper-slide.slider__item
          if props.banner
            figure.slider__banner
              img(src="./assets/images/wallpaper/wallpaper-10.PNG" alt="")
              
          if props.zone
            +zone-card({
              src: './assets/images/fun-2.jpg',
              title: 'Ресторан',
              text: 'Не просто взвешивание и замеры, а функциональные тесты. На их основе тренер построит ваш персональный фитнес-план именно для вашей цели.',
            })
      
    div.slider__scrollbar
