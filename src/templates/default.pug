doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="format-detection" content="telephone=no")
    meta(name="theme-color" content="#231f20")

    <link rel="preload" href="./assets/fonts/Inter/Inter-400.woff2" as="font" crossorigin="anonymous">
    <link rel="preload" href="./assets/fonts/EuropeExt/EuropeExt-700.woff" as="font" crossorigin="anonymous">
    //- favicons
    <link rel="apple-touch-icon" sizes="180x180" href="./assets/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="./assets/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="./assets/favicons/favicon-16x16.png">
    <link rel="manifest" href="./assets/favicons/site.webmanifest">
    <link rel="mask-icon" href="./assets/favicons/safari-pinned-tab.svg" color="#5bbad5">
    <link rel="shortcut icon" href="./assets/favicons/favicon.ico">
    <meta name="msapplication-TileColor" content="#2d89ef">
    <meta name="msapplication-TileImage" content="./assets/favicon/mstile-144x144.png">
    <meta name="msapplication-config" content="./assets/favicon/browserconfig.xml">
    <meta name="theme-color" content="#ffffff">
    //- favicons

    title Sokfit

    //- место для подключения стилей jquery библиотек
    //- link(href='libsJQ/test.css' rel='stylesheet')

  body
    block mixins
      include ../components/modal/modal
      include ../components/alert/alert
      include ../components/layout/layout
      include ../components/title/title
      include ../components/h2/h2
      include ../components/tabs/tabs
      include ../components/direction-tabs/direction-tabs
      include ../components/article-title/article-title
      include ../components/article/article
      include ../components/politics/politics
      include ../components/socials/socials

    block header
      include ../components/header/header

    main
      block main

    block footer
      include ../components/footer/footer
      include ../components/up/up
      include ../components/widget/widget

    include ../react/providers/common/RequestModalProvider/RequestModalProvider

    include ../components/alert-wrapper/alert-wrapper

    template#cookie
      include ../components/cookie/cookie

    div
      template#alert--request
        +alert({
          request: true,
        })

      template#alert--error
        +alert({
          error: true,
        })

      template#alert--wrongtypefile
        +alert({
          wrongtypefile: true,
        })

      template#alert--wrongcountfile
        +alert({
          wrongcountfile: true,
        })

      template#alert--copy
        +alert({
          copy: true,
        })

    div
      template#modal--card
        +modal({
          card: true,
        })

      template#modal--more
        +modal({
          more: true,
        })

    //- jQuery скрипты
    script(src='libsJQ/jquery.min.js')
    block meta